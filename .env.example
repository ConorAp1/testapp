# =============================================================================
# TestApp — Environment Variable Reference
# =============================================================================
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local or any file with real credentials to the repository.
#
# Required for: Next.js + TypeScript + Tailwind + PostgreSQL + Prisma stack
# =============================================================================


# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL + Prisma)
# -----------------------------------------------------------------------------

# Full PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME?schema=public
# For local development, use a local Postgres instance or Docker.
# Example (local): postgresql://postgres:yourpassword@localhost:5432/testapp_dev?schema=public
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/testapp_dev?schema=public"

# Optional: Separate URL for Prisma migrations if using connection pooling (e.g., PgBouncer).
# If not using a connection pooler, leave this the same as DATABASE_URL or omit it.
# DIRECT_URL="postgresql://postgres:yourpassword@localhost:5432/testapp_dev?schema=public"


# -----------------------------------------------------------------------------
# NEXT.JS APPLICATION
# -----------------------------------------------------------------------------

# The public-facing URL of the application.
# Used for generating absolute URLs (e.g., invite links, redirects).
# Local development: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Node environment. Set to "production" in your deployment environment.
# Options: development | test | production
NODE_ENV="development"


# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------

# Secret used to sign and encrypt session tokens / JWTs.
# Generate a strong random value: openssl rand -base64 32
# This must be a long, random, private string. Never share or expose it.
AUTH_SECRET="replace-with-a-long-random-secret-string"

# Authentication provider URL (if using NextAuth.js or similar).
# Set this to your app's base URL. Used internally by the auth library.
NEXTAUTH_URL="http://localhost:3000"

# Secret for NextAuth.js (can be the same as AUTH_SECRET or a separate value).
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret-string"


# -----------------------------------------------------------------------------
# EMAIL (Optional for MVP — used for team invitations if implemented)
# -----------------------------------------------------------------------------

# SMTP configuration for sending emails (e.g., team member invite links).
# For local development without email: leave blank or use a tool like Mailhog.
# For production without budget: use a free tier of Resend, Mailgun, or Gmail SMTP.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM="TestApp <noreply@example.com>"


# -----------------------------------------------------------------------------
# OPTIONAL / FUTURE USE
# -----------------------------------------------------------------------------

# Log level for server-side logging.
# Options: debug | info | warn | error
LOG_LEVEL="info"

# Feature flag: enable or disable the dashboard view during development.
# Set to "true" to enable, "false" to hide behind a flag.
NEXT_PUBLIC_FEATURE_DASHBOARD="true"

# Feature flag: enable task assignment feature during development.
NEXT_PUBLIC_FEATURE_TASK_ASSIGNMENT="true"